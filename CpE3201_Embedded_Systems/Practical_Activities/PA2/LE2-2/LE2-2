#include <xc.h> 

#pragma config FOSC = XT
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF


void delay (unsigned char cnt){
   int i, j;
   for (i = cnt; i!=0; i--){
       for (j=0; j<1000; j++){}
      }
}

void dataCtrl(unsigned char INST){
   PORTB = INST;
   RC0 = 1;
   RC2 = 0;
   RC1 = 1;
   delay(1);
   RC1 = 0;
}

void instCtrl(unsigned char INST){
   PORTB = INST;
   RC0 = 0;
   RC2 = 0;
   RC1 = 1;
   delay(1);
   RC1 = 0;
}

void main(void){

   unsigned char DATA;
   TRISB = 0x00;
   TRISC = 0x00;
   TRISD = 0xFF;
   
   initLCD(); 
   instCtrl(0x80); // move cursor to 2nd line 7th column

   while(1){
   DATA = PORTD & 0x0F
   while (RD4){
	 switch(DATA){
	    case 0x00: 
	       PORTB = 0X01; //Display '1' in binary
	       break;
	    case 0x01: 
	       PORTB = 0X02; //Display '2' in binary
	       break;
	    case 0x02: 
	       PORTB = 0X03;
	       break;
	    case 0x04: 
	       PORTB = 0X04;
	       break;
	    case 0x05: 
	       PORTB = 0X05;
	       break;
	    case 0x06: 
	       PORTB = 0X06;
	       break;
	    case 0x08: 
	       PORTB = 0X07;
	       break;
	    case 0x09: 
	       PORTB = 0X08;
	       break;
	    case 0x0A: 
	       PORTB = 0X09;
	       break;
	   case 0x00: 
	       PORTB = 0X00;
	       break;
	   default: 
	       PORTB = 0X1F;
	       break;
	 }
      }
   }

 }